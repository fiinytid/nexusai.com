{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/chats/:id", "destination": "/chats.html?id=:id" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/payment", "destination": "/payment.html" },
    { "source": "/setup-discord-app", "destination": "/setup-discord-app.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/admin-panel", "destination": "/admin-panel.html" },
    { "source": "/inbox", "destination": "/inbox.html" },
    { "source": "/agent", "destination": "/agent.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
