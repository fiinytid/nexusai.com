{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/chats",              "destination": "/index.html" },
    { "source": "/login",             "destination": "/login.html" },
    { "source": "/",                  "destination": "/dashboard.html" },
    { "source": "/payment",           "destination": "/payment.html" },
    { "source": "/setup-discord-app", "destination": "/discord-app.html" },
    { "source": "/privacy",           "destination": "/privacy.html" },
    { "source": "/terms",             "destination": "/terms.html" },
    { "source": "/admin-panel",       "destination": "/actions.html" },
    { "source": "/inbox",             "destination": "/inbox.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
